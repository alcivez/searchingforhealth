# Cache static assets for 1 year
/images/*
  Cache-Control: public, max-age=31536000, immutable

# Cache promo images for 1 month
/promo-*
  Cache-Control: public, max-age=2592000

# Cache logo and favicon for 1 year
/logo.*
/favicon.*
  Cache-Control: public, max-age=31536000, immutable

# Cache manifest for 1 day
/manifest.json
  Cache-Control: public, max-age=86400

# Cache service worker for 1 day
/sw.js
  Cache-Control: public, max-age=86400

# Cache HTML pages for 1 hour (allows for updates)
/*.html
  Cache-Control: public, max-age=3600

# Cache JSON data files for 1 day
/*.json
  Cache-Control: public, max-age=86400